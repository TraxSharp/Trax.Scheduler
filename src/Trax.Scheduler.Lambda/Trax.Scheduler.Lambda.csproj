<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <Authors>Theauxm,mark-keaton</Authors>
    <PackageDescription>AWS Lambda transport for Trax scheduler job dispatch and synchronous run execution</PackageDescription>
    <RepositoryUrl>https://github.com/TraxSharp/Trax.Scheduler</RepositoryUrl>
    <AssemblyName>Trax.Scheduler.Lambda</AssemblyName>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="../Trax.Scheduler/Trax.Scheduler.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="AWSSDK.Lambda" Version="4.*" />
  </ItemGroup>
</Project>
